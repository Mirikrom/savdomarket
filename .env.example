# SavdoPro — nusxa oling: cp .env.example .env
# Gitga faqat shu fayl ketadi; .env hech qachon commit qilmang.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (docker-compose: DB_HOST=db) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=savdopro
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# --- CORS (frontend manzillari, vergul bilan) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- SMS (Eskiz; dev da ConsoleSmsBackend ishlatiladi) ---
SMS_BACKEND=accounts.services.sms.ConsoleSmsBackend
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Auth ---
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
