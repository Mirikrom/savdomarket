# SavdoPro — nusxa: cp .env.example .env
# Lokal va production bir xil host portlari (ichki container portlari o'zgarmaydi).

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
SERVE_MEDIA=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (Django → container ichida db:5432) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=savdopro
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# --- Docker host portlari (lokal = prod) ---
POSTGRES_PUBLISH_PORT=54311
BACKEND_PUBLISH_PORT=8011
FRONTEND_PUBLISH_PORT=51711

# --- CORS (FRONTEND_PUBLISH_PORT bilan mos) ---
CORS_ALLOWED_ORIGINS=http://localhost:51711,http://127.0.0.1:51711,https://localhost:51711,https://127.0.0.1:51711

# --- Frontend ---
CHOKIDAR_USEPOLLING=true

# --- SMS ---
# Lokal: konsolga kod chiqadi
SMS_BACKEND=accounts.services.sms.ConsoleSmsBackend
# Production: devsms.uz
# SMS_BACKEND=accounts.services.sms.DevsmsBackend
# DEVSMS_TOKEN=your-bearer-token-from-devsms-uz
# DEVSMS_FROM=4546
# DEVSMS_CALLBACK_URL=
# DEVSMS_API_URL=https://devsms.uz/api/send_sms.php
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Auth ---
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
