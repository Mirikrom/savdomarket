# SavdoPro — nusxa: cp .env.example .env
# Gitga faqat .env.example; .env hech qachon commit qilmang.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (Django ulanishi) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=savdopro
DB_USER=postgres
DB_PASSWORD=postgres
# Docker ichida: db:5432. Hostda containersiz Django: DB_HOST=127.0.0.1
DB_HOST=db
DB_PORT=5432

# --- Docker: host portlari (tashqaridan kirish) ---
# Ichki container portlari o'zgarmaydi (postgres 5432, backend 8000, frontend 5173)
# Production namuna: POSTGRES_PUBLISH_PORT=54311, BACKEND_PUBLISH_PORT=8011, FRONTEND_PUBLISH_PORT=51711
POSTGRES_PUBLISH_PORT=5432
BACKEND_PUBLISH_PORT=8000
FRONTEND_PUBLISH_PORT=5173

# --- CORS (brauzer ochadigan frontend manzillari) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5173,https://127.0.0.1:5173

# --- Frontend (ixtiyoriy) ---
CHOKIDAR_USEPOLLING=true

# --- SMS ---
SMS_BACKEND=accounts.services.sms.ConsoleSmsBackend
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Auth ---
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
