# Production server .env namunasi
# 1) cp .env.production.example .env
# 2) SERVER_IP ni serveringiz IP yoki domen bilan almashtiring
# 3) DJANGO_SECRET_KEY va DB_PASSWORD ni o'zingiznikiga qo'ying
# 4) docker compose up -d --build

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# SERVER_IP o'rniga masalan: 192.168.1.50 yoki kassa.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,backend,SERVER_IP

# --- PostgreSQL (container ichida — doim db:5432) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=savdopro
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# --- Docker host portlari (serveringizdagi ochiq portlar) ---
POSTGRES_PUBLISH_PORT=54311
BACKEND_PUBLISH_PORT=8011
FRONTEND_PUBLISH_PORT=51711

# --- CORS: brauzer qaysi manzildan ochsa, shu yerda bo'lishi kerak ---
# SERVER_IP ni almashtiring; domen bo'lsa https://domen.uz:51711 qo'shing
CORS_ALLOWED_ORIGINS=http://SERVER_IP:51711,https://SERVER_IP:51711,http://localhost:51711,https://localhost:51711,http://127.0.0.1:51711,https://127.0.0.1:51711

# --- Frontend ---
CHOKIDAR_USEPOLLING=true

# --- SMS ---
SMS_BACKEND=accounts.services.sms.ConsoleSmsBackend
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Auth ---
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
